# Git LFS for large model files
*.pkl filter=lfs diff=lfs merge=lfs -text
*.pt filter=lfs diff=lfs merge=lfs -text
*.npz filter=lfs diff=lfs merge=lfs -text
*.npy filter=lfs diff=lfs merge=lfs -text

# Large JSON model artefacts (XGBoost weights, static aggs) — only the heavy ones
**/models/xgb_*.json filter=lfs diff=lfs merge=lfs -text
**/models/static_aggs.json filter=lfs diff=lfs merge=lfs -text
