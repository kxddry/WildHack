# WildHack transport-dispatch stack — environment template
# ---------------------------------------------------------
# Copy to .env on first clone:
#     cp .env.example .env
# Then tweak only the values you actually need to override.
# Every variable below has a sane default in docker-compose.yml, so
# .env is optional for a vanilla `compose up`.
#
# For the one-command judge/demo flow you usually do not need to edit
# anything here: `scripts/judge/up.sh` auto-creates `.env` from this file
# on first run and boots the stack with the bundled sample data.

# ---------- Compose project ----------
# Pins the image namespace + network + volume prefix. Two clones of this
# repo on the same machine share the same prefix only if this matches.
COMPOSE_PROJECT_NAME=wildhack

# Default platform for built images. Pin to linux/amd64 so Apple Silicon
# devs and Linux CI runners produce identical images. Override to
# linux/arm64 for native M-series builds.
IMAGE_PLATFORM=linux/amd64

# ---------- PostgreSQL ----------
POSTGRES_DB=wildhack
POSTGRES_USER=wildhack
POSTGRES_PASSWORD=wildhack_dev
POSTGRES_PORT=5432

# Convenience URL for tools that take a single DSN. Compose builds the
# in-network URL itself from POSTGRES_* — this one is for host-side
# tooling (psql, pgcli, dbeaver) over the loopback bind.
DATABASE_URL=postgresql+asyncpg://wildhack:wildhack_dev@127.0.0.1:5432/wildhack

# ---------- Service host ports ----------
# Override these if a port is already taken on your machine.
PREDICTION_PORT=8000
DISPATCHER_PORT=8001
SCHEDULER_PORT=8002
RETRAINING_PORT=8003
DASHBOARD_PORT=4000
PROMETHEUS_PORT=9090
# Defaulted to 3001 to dodge collisions with `next dev` on 3000.
GRAFANA_PORT=3001

# ---------- Prediction service ----------
# Set MOCK_MODE=1 to enable the synthetic-fallback predictor when
# model.pkl / static_aggs.json / fill_values.json are missing. Leave
# unset (or =0) for any environment that should serve real predictions —
# the service will then fail-fast at startup with a clear error instead
# of silently emitting fake forecasts.
MOCK_MODE=0

# ---------- Dispatcher service ----------
TRUCK_CAPACITY=33
BUFFER_PCT=0.10
MIN_TRUCKS=1
ADAPTIVE_BUFFER=false
MIN_BUFFER_PCT=0.05
MAX_BUFFER_PCT=0.25

# ---------- Scheduler service ----------
PREDICTION_INTERVAL_MINUTES=30
QUALITY_CHECK_INTERVAL_MINUTES=60

# ---------- Retraining service ----------
TRAINING_WINDOW_DAYS=7
# Retention window applied by POST /upload-dataset. The upload is treated
# as the authoritative rolling snapshot, so everything older than
# max(upload.timestamp) - UPLOAD_RETENTION_DAYS is pruned in the same
# transaction as the ingest. Training for the force-promote retrain also
# runs on this same window — keep the two settings aligned so the model
# trains on exactly what the dispatcher will see.
UPLOAD_RETENTION_DAYS=7

# ---------- Dispatcher step interval ----------
# Width of a single dispatch slot in minutes. Must match the upstream
# prediction-service step interval; kept on the dispatcher so the two
# services can be tuned independently during migration.
STEP_INTERVAL_MINUTES=30

# ---------- Shared secrets ----------
# MANDATORY — every deployment must populate these, including local dev.
# The services fail closed (503) if either is empty. No defaults are
# baked into docker-compose.yml on purpose; past "local-dev-token-change-me"
# placeholders leaked into shared dev boxes and had to be rotated manually.
# For a laptop-only demo or jury run, the placeholder values below are
# acceptable; rotate them before using any shared or network-exposed env.
#
# Generate strong values before your first `compose up`:
#     openssl rand -hex 32
#
# DATA_INGEST_TOKEN  — protects POST /upload-dataset. Dashboard BFF proxy
#                      injects it on the X-Ingest-Token header. Browsers
#                      cannot forge the header on a cross-origin multipart
#                      POST, so it doubles as CSRF protection.
# INTERNAL_API_TOKEN — protects service-to-service control routes:
#                        * scheduler /pipeline/trigger
#                        * prediction /model/reload, /model/reload-features,
#                                     /model/shadow/load, /model/shadow/promote,
#                                     DELETE /model/shadow
#                      Callers send it on the X-Internal-Token header.
#
# Rotate by:
#   1. Generate a new hex string with `openssl rand -hex 32`.
#   2. Update the value in every .env file that pins it.
#   3. Restart the affected services (compose restart <svc>).
DATA_INGEST_TOKEN=replace-me-with-openssl-rand-hex-32
INTERNAL_API_TOKEN=replace-me-with-openssl-rand-hex-32

# ---------- Grafana ----------
GF_SECURITY_ADMIN_PASSWORD=admin
