# PostgreSQL
POSTGRES_DB=wildhack
POSTGRES_USER=wildhack
POSTGRES_PASSWORD=wildhack_dev
DATABASE_URL=postgresql+asyncpg://wildhack:wildhack_dev@postgres:5432/wildhack

# Redis (optional, for future use)
REDIS_URL=redis://redis:6379/0

# Prediction Service
MODEL_PATH=/app/models/model.pkl

# Dispatcher Service
TRUCK_CAPACITY=33
BUFFER_PCT=0.10
MIN_TRUCKS=1

# Dashboard
PREDICTION_SERVICE_URL=http://prediction-service:8000
DISPATCHER_SERVICE_URL=http://dispatcher-service:8001

# Grafana
GF_SECURITY_ADMIN_PASSWORD=admin
